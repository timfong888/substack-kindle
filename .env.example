# Copy to .env (gitignored) and fill in locally. NEVER commit real values.

# Postmark (transactional email — sends the EPUB and notifications)
POSTMARK_SERVER_TOKEN=
# Verified Postmark sender signature (shared system identity). Its local-part
# MUST be distinct from each customer's Kindle address local-part — Amazon
# fires the "Verify document" email on every send when they match (SAT-270).
# Example value: kindle_whitelist@fong888.com
WHITELIST_EMAIL=
POSTMARK_MESSAGE_STREAM=outbound

# The customer's Kindle delivery address (used as the Postmark "To" value).
# Example: timfong888@kindle.com
KINDLE_EMAIL=

# RSS ingestion (free Substacks — the primary path, no Gmail/OAuth).
# Feed registry JSON: {"feeds": ["https://<pub>.substack.com/feed", ...]}.
FEEDS_PATH=~/.config/substack-kindle/feeds.json

# Gmail read-only OAuth — DORMANT. Only needed for the deferred paid-Substack
# path (truncated RSS); the free-Substack RSS pipeline does not use Gmail.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Bundle directory holding client_secret.json + credentials.json for the CLI.
GMAIL_BUNDLE_PATH=~/.config/substack-kindle/gmail/

# Code review runs via the CodeRabbit GitHub App — no API key needed in this repo.
