# Copy to .env (gitignored) and fill in locally. NEVER commit real values.

# Postmark (transactional email — sends the EPUB and notifications)
POSTMARK_SERVER_TOKEN=
WHITELIST_EMAIL=                 # verified Postmark sender signature (shared system identity)
POSTMARK_MESSAGE_STREAM=outbound

# Gmail read-only OAuth (per customer; supplied at runtime in production)
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# Greptile (lives in Claude Code config / GitHub App in practice — here for local tooling only)
GREPTILE_API_KEY=
